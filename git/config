[user]
	name = Michal Pielka
	email = mpielka726@gmail.com
	signingkey = ~/.ssh/id_ed25519

[core]
	editor = nvim
	pager = delta
	compression = 9
	whitespace = error

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	syntax-theme = gruvbox-dark

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
	context = 3

[init]
	defaultBranch = main

[advice]
	addEmptyPathspec = false
	pushNonFastForward = false
	statusHints = false

[status]
	showStash = true

[url "git@github.com:"]
	insteadOf = "gh:"

[color "diff"]
	commit = cyan

[gpg]
	format = ssh

[commit]
	gpgsign = true

[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
